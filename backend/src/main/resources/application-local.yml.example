# Copie este arquivo para "application-local.yml" (mesma pasta) e preencha
# com sua chave real do sandbox Asaas. application-local.yml esta no
# .gitignore - nunca sera commitado.
#
# Para ativar: mvn spring-boot:run -Dspring-boot.run.profiles=local
# (ou SPRING_PROFILES_ACTIVE=local se estiver rodando o jar diretamente)

facilitei:
  asaas:
    api-key: COLE_AQUI_SUA_CHAVE_SANDBOX_DO_ASAAS
  # Para ativar o envio real de WhatsApp via MyZap: cole a "chave fixa"
  # (mz_...) obtida em Login + GET /api/chaves/fixa no painel do MyZap, e
  # troque notification.provider para "myzap". Deixe "console" (default) se
  # so quiser ver a notificacao logada no terminal do backend.
  myzap:
    api-key: COLE_AQUI_A_CHAVE_FIXA_MZ
  notification:
    provider: console
